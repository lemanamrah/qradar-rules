[
  {
    "name": "Suspicious VPN Login Location",
    "description": "Detects VPN logins from unauthorized geographic locations.",
    "enabled": true,
    "type": "ADE_RULE",
    "source_data": {
      "strategy": "simple_logic",
      "conditions": [
        {
          "field": "Event Name",
          "operator": "EQUALS",
          "value": "VPN Login Successful"
        },
        {
          "field": "Source Region",
          "operator": "NOT_IN",
          "value": "AZ,TR,EU"
        }
      ]
    },
    "trigger": {
      "severity": 8,
      "offense_type": "Source IP"
    }
  }
]
