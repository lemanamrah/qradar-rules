[
  {
    "name": "Unauthorized Database Dump",
    "description": "Detects large-scale database dump operations performed without authorization.",
    "enabled": true,
    "type": "ADE_RULE",
    "source_data": {
      "strategy": "simple_logic",
      "conditions": [
        {
          "field": "Event Name",
          "operator": "EQUALS",
          "value": "Database Dump"
        },
        {
          "field": "User Name",
          "operator": "NOT_IN",
          "value": "DBAdmin,SecOps"
        }
      ]
    },
    "trigger": {
      "severity": 10,
      "offense_type": "Database"
    }
  }
]
