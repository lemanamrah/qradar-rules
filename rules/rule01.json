{
  "name": "Multiple Failed Logins Followed by Success",
  "description": "Detects brute-force attempts where multiple failed logins are followed by a successful login.",
  "rule_type": "event",
  "conditions": [
    {
      "field": "EventName",
      "operator": "equals",
      "value": "Failed Login"
    },
    {
      "field": "Count",
      "operator": "greater_than",
      "value": 5
    }
  ],
  "follow_up": {
    "field": "EventName",
    "operator": "equals",
    "value": "Successful Login"
  },
  "response": "Generate offense with severity High"
}
