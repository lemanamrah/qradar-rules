{
  "name": "Suspicious LDAP Query Volume",
  "description": "Detects unusually high volumes of LDAP queries which may indicate domain enumeration or credential harvesting.",
  "rule_type": "event",
  "conditions": [
    {
      "field": "EventName",
      "operator": "equals",
      "value": "LDAP Query"
    },
    {
      "field": "Count",
      "operator": "greater_than",
      "value": 100
    }
  ],
  "follow_up": {
    "field": "SourceIP",
    "operator": "not_in",
    "value": ["192.168.75.10", "192.168.75.11"]
  },
  "response": "Generate offense with severity Critical"
}
