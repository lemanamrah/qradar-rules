{
  "name": "Unauthorized Database Dump",
  "description": "Detects large-scale database dump operations performed without authorization, which may indicate data exfiltration.",
  "rule_type": "event",
  "conditions": [
    {
      "field": "EventName",
      "operator": "equals",
      "value": "Database Dump"
    },
    {
      "field": "DumpSizeMB",
      "operator": "greater_than",
      "value": 500
    }
  ],
  "follow_up": {
    "field": "Username",
    "operator": "not_in",
    "value": ["DBAdmin", "SecOps"]
  },
  "response": "Generate offense with severity Critical"
}
