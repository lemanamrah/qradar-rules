[
  {
    "name": "Suspicious LDAP Query Volume",
    "description": "Detects unusually high volumes of LDAP queries indicating domain enumeration.",
    "enabled": true,
    "type": "ADE_RULE",
    "source_data": {
      "strategy": "simple_logic",
      "conditions": [
        {
          "field": "Event Name",
          "operator": "EQUALS",
          "value": "LDAP Search"
        },
        {
          "field": "Source IP",
          "operator": "NOT_IN",
          "value": "192.168.75.10,192.168.75.11"
        }
      ]
    },
    "trigger": {
      "threshold": 100,
      "window": "10m",
      "severity": 9,
      "offense_type": "Source IP"
    }
  }
]
