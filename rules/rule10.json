[
  {
    "name": "Suspicious File Share Access",
    "description": "Detects unusual or unauthorized access to file shares, indicating potential insider threat.",
    "enabled": true,
    "type": "ADE_RULE",
    "source_data": {
      "strategy": "simple_logic",
      "conditions": [
        {
          "field": "Event Name",
          "operator": "EQUALS",
          "value": "File Share Access"
        },
        {
          "field": "User Name",
          "operator": "NOT_IN",
          "value": "FileAdmin,SecOps"
        }
      ]
    },
    "trigger": {
      "threshold": 200,
      "window": "15m",
      "severity": 8,
      "offense_type": "Source IP"
    }
  }
]
