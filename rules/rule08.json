[
  {
    "name": "Malware Beaconing Pattern",
    "description": "Detects periodic outbound connections matching beaconing behavior.",
    "enabled": true,
    "type": "ADE_RULE",
    "source_data": {
      "strategy": "simple_logic",
      "conditions": [
        {
          "field": "Direction",
          "operator": "EQUALS",
          "value": "Outbound"
        },
        {
          "field": "Destination Domain",
          "operator": "MATCHES",
          "value": ".*(dynamicdns|unknown|suspicious).*"
        }
      ]
    },
    "trigger": {
      "severity": 10,
      "offense_type": "Destination IP"
    }
  }
]
