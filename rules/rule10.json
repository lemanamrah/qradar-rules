{
  "name": "Suspicious File Share Access",
  "description": "Detects unusual or unauthorized access to file shares, which may indicate insider threat or data theft.",
  "rule_type": "event",
  "conditions": [
    {
      "field": "EventName",
      "operator": "equals",
      "value": "File Share Access"
    },
    {
      "field": "AccessCount",
      "operator": "greater_than",
      "value": 200
    }
  ],
  "follow_up": {
    "field": "Username",
    "operator": "not_in",
    "value": ["FileAdmin", "SecOps"]
  },
  "response": "Generate offense with severity High"
}
